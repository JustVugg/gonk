GONK_IMAGE=ghcr.io/justvugg/gonk:latest
GONK_HTTP_PORT=8080
GONK_CONFIG=./configs/gonk.production.yaml
GONK_CERTS_DIR=./certs

GONK_ADMIN_TOKEN=replace-with-a-long-random-admin-token
JWT_SECRET=replace-with-at-least-32-random-bytes
API_KEY_1=replace-with-a-long-random-api-key
UPSTREAM_URL=http://127.0.0.1:3000
